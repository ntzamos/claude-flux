############################################################
# Claude Telegram Relay — Environment
#
# Copy to .env and fill in the required values below.
# Everything else (Telegram token, API keys, etc.) is
# entered via the web UI at http://localhost after running:
#   docker compose up -d
############################################################

## ── Required ────────────────────────────────────────────────

## PostgreSQL password — choose any strong password
POSTGRES_PASSWORD=your-strong-postgres-password-here

## ── Port overrides (optional) ───────────────────────────────

## Web dashboard port (default: 80 → http://localhost)
# WEB_PORT=80


############################################################
# Quick start:
#   cp .env.example .env
#   docker compose up -d
#   open http://localhost    <- onboarding + dashboard
############################################################
